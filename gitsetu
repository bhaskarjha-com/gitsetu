#!/usr/bin/env bash
# gitsetu — One command. All identities. Every machine.
#
# A zero-dependency CLI tool for automated Git multi-identity
# and SSH key setup. Clone, run, done.
#
# Usage: ./gitsetu setup [--dry-run]
#        ./gitsetu status
#        ./gitsetu verify
#        ./gitsetu guard --install | --uninstall
#        ./gitsetu --help | --version
#
# https://github.com/bhaskarjha-com/gitsetu
# MIT License — Bhaskar Jha

# --- CRLF self-healing for VirtualBox shared folders ---
# vboxsf injects \r into all files. Unconditionally re-exec through tr on first run.
# tr -d '\r' is a no-op on clean files, so this is safe everywhere.
if ! command -v tr >/dev/null 2>&1; then echo "Error: 'tr' command is required but not found." >&2; exit 1; fi
# shellcheck disable=SC2270
test "${GITSETU_CRLF_CLEAN:-}" = "1" || { export GITSETU_CRLF_CLEAN=1; export GITSETU_ORIG_SCRIPT="${BASH_SOURCE[0]:-$0}"; exec bash <(tr -d '\r' < "${BASH_SOURCE[0]:-$0}") "$@"; }

set -euo pipefail

# ------------------------------------------------------------------------------
# Resolve script directory (handles symlinks, $0 fallback, vboxsf CRLF re-exec)
# ------------------------------------------------------------------------------
resolve_script_dir() {
    # When re-executed for CRLF cleaning, BASH_SOURCE is /dev/fd/N.
    # Use GITSETU_ORIG_SCRIPT (set before re-exec) to find the real script.
    # Strip \r because the env var was set from a CRLF-contaminated line.
    local source
    source=$(printf '%s' "${GITSETU_ORIG_SCRIPT:-${BASH_SOURCE[0]:-$0}}" | tr -d '\r')

    # If source is empty or just a basename, try $0
    if [[ -z "$source" ]] || [[ "$source" == "bash" ]]; then
        source="$0"
    fi

    # If still relative, make it absolute
    if [[ "$source" != /* ]]; then
        source="$(pwd)/$source"
    fi

    # Resolve symlinks
    while [[ -L "$source" ]]; do
        local link_dir
        link_dir=$(cd -P "$(dirname "$source")" 2>/dev/null && pwd)
        source=$(readlink "$source")
        if [[ "$source" != /* ]]; then
            source="$link_dir/$source"
        fi
    done

    local dir
    dir=$(cd -P "$(dirname "$source")" 2>/dev/null && pwd)
    printf '%s' "$dir"
}

GITSETU_SCRIPT_DIR=$(resolve_script_dir | tr -d '\r')

# ------------------------------------------------------------------------------
# Source all library modules
# Strip \r from sourced files for vboxsf compatibility
# ------------------------------------------------------------------------------
gitsetu_source() {
    # shellcheck disable=SC1090
    eval "$(tr -d '\r' < "$1")"
}
gitsetu_source "$GITSETU_SCRIPT_DIR/lib/core.sh"
gitsetu_source "$GITSETU_SCRIPT_DIR/lib/platform.sh"
gitsetu_source "$GITSETU_SCRIPT_DIR/lib/ui.sh"
gitsetu_source "$GITSETU_SCRIPT_DIR/lib/validate.sh"
gitsetu_source "$GITSETU_SCRIPT_DIR/lib/backup.sh"
gitsetu_source "$GITSETU_SCRIPT_DIR/lib/ssh.sh"
gitsetu_source "$GITSETU_SCRIPT_DIR/lib/gitconfig.sh"
gitsetu_source "$GITSETU_SCRIPT_DIR/lib/guard.sh"
gitsetu_source "$GITSETU_SCRIPT_DIR/lib/doctor.sh"
gitsetu_source "$GITSETU_SCRIPT_DIR/lib/verify.sh"
gitsetu_source "$GITSETU_SCRIPT_DIR/lib/teardown.sh"
gitsetu_source "$GITSETU_SCRIPT_DIR/lib/discovery.sh"
gitsetu_source "$GITSETU_SCRIPT_DIR/lib/setup.sh"
gitsetu_source "$GITSETU_SCRIPT_DIR/lib/keychain.sh"

# ------------------------------------------------------------------------------
# Unified Global Cleanup Architecture
# ------------------------------------------------------------------------------
GITSETU_CLEANUP_FILES=()
GITSETU_CLEANUP_DIRS=()

gitsetu_global_cleanup() {
    local f d
    for f in "${GITSETU_CLEANUP_FILES[@]}"; do
        rm -f "$f" 2>/dev/null || true
    done
    for d in "${GITSETU_CLEANUP_DIRS[@]}"; do
        rmdir "$d" 2>/dev/null || true
    done
}

cleanup() {
    printf >&2 '\n'
    print_warning "Interrupted. No changes were made (or partial changes were backed up)."
    gitsetu_global_cleanup
    exit 130
}
trap gitsetu_global_cleanup EXIT
trap cleanup SIGINT SIGTERM

# ------------------------------------------------------------------------------
# Usage / Help text
# ------------------------------------------------------------------------------
show_help() {
    cat >&2 <<EOF
${BOLD}gitsetu${RESET} v${GITSETU_VERSION} — One command. All identities. Every machine.

${BOLD}USAGE${RESET}
    gitsetu setup [--dry-run]        Interactive setup wizard
    gitsetu status                   Show current identity configuration
    gitsetu verify                   Test SSH keys and git config
    ${CYAN}gitsetu backup [out_file]${RESET}    Export encrypted identity state
    ${CYAN}gitsetu restore <in_file>${RESET}    Import encrypted identity state
    gitsetu run <profile> -- <cmd>   Run command as specific identity
    gitsetu teardown [--force] [--deep]  Remove all configurations
                                     --deep: Recursively strip local repository overrides
                                     --force: Bypass confirmation prompt
    gitsetu guard --install          Install pre-commit identity guard hook
    gitsetu guard --uninstall        Remove the guard hook
    gitsetu --help, -h               Show this help
    gitsetu --version, -v            Show version

${BOLD}DESCRIPTION${RESET}
    gitsetu automates the setup of multiple Git identities and SSH keys.
    It generates Ed25519 SSH keys, creates ~/.gitconfig with conditional
    includes, sets up ~/.ssh/config host aliases, and verifies everything
    works — all in a single interactive session.

${BOLD}EXAMPLES${RESET}
    ${DIM}# First-time setup:${RESET}
    git clone https://github.com/bhaskarjha-com/gitsetu.git
    cd gitsetu
    ./gitsetu setup

    ${DIM}# Preview what setup would do:${RESET}
    ./gitsetu setup --dry-run

    ${DIM}# Check current identity:${RESET}
    ./gitsetu status

    ${DIM}# Run git as a specific profile:${RESET}
    ./gitsetu run work -- git commit -m "fix"

    ${DIM}# Install commit safety net:${RESET}
    ./gitsetu guard --install

${BOLD}MORE INFO${RESET}
    https://github.com/bhaskarjha-com/gitsetu
EOF
}

show_version() {
    printf 'gitsetu v%s\n' "$GITSETU_VERSION"
}

# ------------------------------------------------------------------------------
# cmd_status — Show current identity configuration
# ------------------------------------------------------------------------------
cmd_status() {
    detect_os

    print_header

    # Current directory info
    local cwd
    cwd=$(pwd)
    print_section "Current Directory"
    printf >&2 '  %s\n\n' "$cwd"

    # Current git identity
    local current_name current_email
    current_name=$(git config user.name 2>/dev/null || echo "(not set)")
    current_email=$(git config user.email 2>/dev/null || echo "(not set)")

    printf >&2 '  %b┌─ Active Identity ─────────────────────────────┐%b\n' "$BOLD" "$RESET"
    printf >&2 '  %b│%b  Name:  %b%s%b\n' "$DIM" "$RESET" "$CYAN" "${current_name}" "$RESET"
    printf >&2 '  %b│%b  Email: %b%s%b\n' "$DIM" "$RESET" "$CYAN" "${current_email}" "$RESET"
    
    # Check if inside a git repo
    if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        local ssh_cmd
        ssh_cmd=$(git config core.sshCommand 2>/dev/null || echo "(default)")
        printf >&2 '  %b│%b  SSH:   %b%s%b\n' "$DIM" "$RESET" "$GREEN" "${ssh_cmd}" "$RESET"
    fi
    printf >&2 '  %b└───────────────────────────────────────────────┘%b\n\n' "$DIM" "$RESET"

    # Show profile registry if it exists
    if [[ -f "$GITSETU_PROFILES_CONF" ]]; then
        print_section "Configured Profiles"

        while IFS=: read -r label email dir provider sign_commits key_path || [[ -n "$label" ]]; do
            [[ "$label" == "#"* ]] && continue
            [[ -z "$label" ]] && continue
            
            local dir_disp="${dir:-[Manual Mode]}"
            local prov_disp="${provider:-github.com}"
            
            # Check if this profile matches current identity
            local is_active="  "
            if [[ "$email" == "$current_email" ]]; then
                is_active="${GREEN}${SYM_CHECK} ${RESET}"
            fi
            
            printf >&2 '  %s%b%s%b\n' "$is_active" "$BOLD" "$label" "$RESET"
            printf >&2 '    %b├─%b %-9s %s\n' "$DIM" "$RESET" "Email:" "$email"
            printf >&2 '    %b├─%b %-9s %s\n' "$DIM" "$RESET" "Provider:" "$prov_disp"
            printf >&2 '    %b└─%b %-9s %s\n\n' "$DIM" "$RESET" "Path:" "$dir_disp"
        done < "$GITSETU_PROFILES_CONF"
    else
        print_info "No profiles configured. Run 'gitsetu setup' to get started."
    fi

    # Platform info
    print_section "Environment"
    printf >&2 '  OS:       %s\n' "$GITSETU_OS"
    printf >&2 '  Bash:     %s\n' "${BASH_VERSION:-unknown}"
    printf >&2 '  Git:      %s\n' "$(git --version 2>/dev/null | head -n1)"
    printf >&2 '  Config:   %s\n' "$GITSETU_CONFIG_DIR"
    printf >&2 '\n'
}

# ------------------------------------------------------------------------------
# cmd_verify — Run all verification checks
# ------------------------------------------------------------------------------
cmd_verify() {
    detect_os
    print_header

    # Load profiles from registry
    if [[ ! -f "$GITSETU_PROFILES_CONF" ]]; then
        print_error "No profiles configured. Run 'gitsetu setup' first."
        return 1
    fi

    # Read profiles from registry
    load_profiles

    if [[ "$PROFILE_COUNT" -eq 0 ]]; then
        print_error "No profiles found in registry. Run 'gitsetu setup' first."
        return 1
    fi

    verify_all
}

# ------------------------------------------------------------------------------
# cmd_teardown — Remove all gitsetu configurations
# ------------------------------------------------------------------------------
cmd_teardown() {
    detect_os
    print_header

    if [[ "$GITSETU_DRY_RUN" -eq 1 ]]; then
        print_info "DRY RUN MODE — no files will be written/deleted"
        printf >&2 '\n'
    fi

    local force="${1:-0}"
    local deep="${2:-0}"

    if [[ "$force" -eq 0 ]] && [[ "$GITSETU_DRY_RUN" -eq 0 ]]; then
        print_warning "This will remove all GitSetu configurations:"
        printf >&2 "  - Remove managed blocks from ~/.gitconfig\n"
        printf >&2 "  - Remove managed blocks from ~/.ssh/config\n"
        printf >&2 "  - Uninstall the commit guard hook\n"
        printf >&2 "  - Delete the ~/.config/gitsetu directory\n"
        if [[ "$deep" -eq 1 ]]; then
            printf >&2 "  - STRIP local identity overrides from all mapped repositories\n"
        fi
        printf >&2 "\n"
        if ! confirm "Are you sure you want to proceed?" "n"; then
            print_info "Teardown cancelled."
            return 0
        fi
    fi

    teardown_all "$deep"
}

# ------------------------------------------------------------------------------
# cmd_setup — Interactive Blueprint Dashboard / Headless setup
# ------------------------------------------------------------------------------
cmd_setup() {
    detect_os
    print_header

    if [[ "$GITSETU_DRY_RUN" -eq 1 ]]; then
        print_info "DRY RUN MODE — no files will be written"
        printf >&2 '\n'
    fi

    # --- Preflight ---
    print_section "Preflight Checks"
    printf >&2 '  OS detected: %b%s%b\n' "$BOLD" "$GITSETU_OS" "$RESET"

    if ! check_prerequisites; then
        return 1
    fi
    print_success "All prerequisites met"

    # Check for shared folder
    if is_shared_mount "$HOME" 2>/dev/null; then
        print_warning "Home directory appears to be on a shared folder."
        print_info "SSH keys will be stored on the native filesystem at ~/.ssh"
    fi
    
    # Check if TTY
    if [[ ! -t 1 ]]; then
        print_error "Headless setup via args is not yet fully implemented in this block."
        print_error "Use 'gitsetu profile add' for headless mode."
        return 1
    fi

    # Launch the interactive menu
    interactive_setup_wizard
}

# ------------------------------------------------------------------------------
# cmd_run — Execute a command under a specific profile identity
# ------------------------------------------------------------------------------
cmd_run() {
    detect_os
    local profile="$1"
    shift
    
    if [[ -z "$profile" ]]; then
        print_error "Usage: gitsetu run <profile> -- <command>"
        return 1
    fi
    
    if [[ "$1" == "--" ]]; then shift; fi
    
    if [[ $# -eq 0 ]]; then
        print_error "No command provided. Usage: gitsetu run <profile> -- <command>"
        return 1
    fi
    
    # Check if profile exists
    if [[ ! -f "$GITSETU_PROFILES_CONF" ]]; then
        print_error "No profiles configured. Run 'gitsetu setup' first."
        return 1
    fi

    local found=0
    local found_key_path=""
    while IFS=: read -r label email dir provider sign_commits key_path || [[ -n "$label" ]]; do
        if [[ "$label" == "$profile" ]]; then
            found=1
            found_key_path="${key_path:-$HOME/.ssh/id_ed25519_${label}}"
            break
        fi
    done < "$GITSETU_PROFILES_CONF"
    
    if [[ "$found" -eq 0 ]]; then
        print_error "Profile '$profile' not found in registry."
        return 1
    fi
    
    local name email
    local config_file="$GITSETU_PROFILES_DIR/${profile}.gitconfig"
    
    if [[ ! -f "$config_file" ]]; then
        # Global profile (stored in ~/.gitconfig)
        name=$(git config --global user.name 2>/dev/null || echo "")
        email=$(git config --global user.email 2>/dev/null || echo "")
    else
        name=$(git config -f "$config_file" user.name 2>/dev/null || echo "")
        email=$(git config -f "$config_file" user.email 2>/dev/null || echo "")
    fi
    
    export GIT_AUTHOR_NAME="$name"
    export GIT_AUTHOR_EMAIL="$email"
    export GIT_COMMITTER_NAME="$name"
    export GIT_COMMITTER_EMAIL="$email"
    export GIT_SSH_COMMAND="ssh -i ${found_key_path}"
    
    exec "$@"
}

# ------------------------------------------------------------------------------
# cmd_remove — Surgically remove a single profile
# ------------------------------------------------------------------------------
cmd_remove() {
    detect_os
    local profile="$1"
    
    if [[ -z "$profile" ]]; then
        print_error "Usage: gitsetu remove <profile>"
        return 1
    fi
    
    if [[ ! -f "$GITSETU_PROFILES_CONF" ]]; then
        print_error "No profiles configured."
        return 1
    fi
    
    # Check if profile exists
    local found=0
    local found_key_path=""
    while IFS=: read -r label email dir provider sign_commits key_path || [[ -n "$label" ]]; do
        if [[ "$label" == "$profile" ]]; then
            found=1
            found_key_path="${key_path:-$HOME/.ssh/id_ed25519_${label}}"
            break
        fi
    done < "$GITSETU_PROFILES_CONF"
    
    if [[ "$found" -eq 0 ]]; then
        print_error "Profile '$profile' not found."
        return 1
    fi

    if ! confirm "Are you sure you want to completely remove profile '$profile'?" "n"; then
        print_info "Cancelled."
        return 0
    fi
    
    print_step "Removing profile '$profile'..."
    
    # 1. Remove from profiles.conf using awk (sed is non-portable across BSD/GNU without weird syntax)
    local tmp_conf
    tmp_conf=$(mktemp "${GITSETU_PROFILES_CONF}.tmp.XXXXXX")
    GITSETU_CLEANUP_FILES+=("$tmp_conf")
    awk -F: -v prof="$profile" '$1 != prof {print}' "$GITSETU_PROFILES_CONF" > "$tmp_conf"
    mv "$tmp_conf" "$GITSETU_PROFILES_CONF"
    
    # 2. Delete the profile gitconfig
    local config_file="$GITSETU_PROFILES_DIR/${profile}.gitconfig"
    if [[ -f "$config_file" ]]; then
        rm -f "$config_file"
    fi
    
    # 3. Reload in-memory arrays so the writers have the updated state
    # shellcheck disable=SC2034
    PROFILE_LABELS=()
    # shellcheck disable=SC2034
    PROFILE_NAMES=()
    # shellcheck disable=SC2034
    PROFILE_EMAILS=()
    # shellcheck disable=SC2034
    PROFILE_DIRS=()
    # shellcheck disable=SC2034
    PROFILE_PROVIDERS=()
    # shellcheck disable=SC2034
    PROFILE_SIGNS=()
    PROFILE_COUNT=0
    
    while IFS=: read -r label email dir provider sign_commits key_path || [[ -n "$label" ]]; do
        [[ "$label" == "#"* ]] && continue
        [[ -z "$label" ]] && continue
        PROFILE_LABELS+=("$label")
        PROFILE_EMAILS+=("$email")
        PROFILE_DIRS+=("$dir")
        PROFILE_PROVIDERS+=("${provider:-github.com}")
        PROFILE_SIGNS+=("${sign_commits:-0}")
        PROFILE_KEYS+=("${key_path:-$HOME/.ssh/id_ed25519_${label}}")
        PROFILE_COUNT=$((PROFILE_COUNT + 1))
    done < "$GITSETU_PROFILES_CONF"
    
    # Note: We do not reload PROFILE_NAMES from the conf because we never stored them there!
    # Wait, write_global_gitconfig relies on PROFILE_NAMES for the default profile...
    # BUT wait! We deleted the default profile's name/email injection in step 1 of the audit fix!
    # The default profile only needs the label to set sshCommand! It NO LONGER needs PROFILE_NAMES.
    
    # 4. Re-run block generators (idempotent, they will overwrite the global configs without the removed profile)
    write_global_gitconfig >/dev/null
    write_ssh_config >/dev/null
    
    print_success "Profile '$profile' successfully removed."
    
    # Ask about SSH keys
    local key_file="${found_key_path}"
    if [[ -f "$key_file" ]]; then
        printf >&2 '\n'
        print_warning "SSH keys for '$profile' still exist:"
        print_info "  $key_file"
        print_info "  $key_file.pub"
        if confirm "Delete these SSH keys permanently?" "n"; then
            rm -f "$key_file" "$key_file.pub"
            print_success "SSH keys deleted."
        else
            print_info "Keys kept. You can manually delete them later."
        fi
    fi
}


# ------------------------------------------------------------------------------
# cmd_prompt — Zero-latency profile detection for PS1 integration
# ------------------------------------------------------------------------------
cmd_prompt() {
    if [[ ! -f "$GITSETU_PROFILES_CONF" ]]; then
        return 0
    fi

    # Normalize PWD like we do for dirs
    local current_pwd="${PWD%/}"
    
    local matched_profile=""
    local max_len=0

    # Prefix match without subshells
    while IFS=: read -r label email dir provider sign_commits key_path || [[ -n "$label" ]]; do
        [[ -z "$dir" ]] && continue
        
        # Check if PWD starts with the profile dir
        if [[ "$current_pwd/" == "$dir/"* ]] || [[ "$current_pwd" == "$dir" ]]; then
            # Longest match wins
            local dir_len=${#dir}
            if [[ "$dir_len" -gt "$max_len" ]]; then
                max_len=$dir_len
                matched_profile="$label"
            fi
        fi
        done < "$GITSETU_PROFILES_CONF"

    if [[ -n "$matched_profile" ]]; then
        echo "$matched_profile"
    fi
}

# ------------------------------------------------------------------------------
# cmd_credential — Git Credential Helper Broker
# ------------------------------------------------------------------------------
cmd_credential() {
    local action="${1:-}"
    if [[ -z "$action" ]]; then
        return 1
    fi

    # Read from stdin
    local host=""
    local protocol=""
    local username=""
    local password=""

    while read -r line; do
        [[ -z "$line" ]] && break
        case "$line" in
            host=*) host="${line#*=}" ;;
            protocol=*) protocol="${line#*=}" ;;
            username=*) username="${line#*=}" ;;
            password=*) password="${line#*=}" ;;
        esac
    done

    # We only care about https and host
    if [[ "$protocol" != "https" ]] || [[ -z "$host" ]]; then
        return 0
    fi

    # Identify profile context
    local profile
    profile=$(cmd_prompt)
    if [[ -z "$profile" ]]; then
        # Not in a profile directory, ignore
        return 0
    fi

    detect_os

    case "$action" in
        get)
            keychain_get "$profile" "$host"
            ;;
        store)
            if [[ -n "$username" ]] && [[ -n "$password" ]]; then
                keychain_store "$profile" "$host" "$username" "$password"
            fi
            ;;
        erase)
            keychain_erase "$profile" "$host"
            ;;
    esac
}

# ------------------------------------------------------------------------------
# cmd_doctor — Run diagnostics
# ------------------------------------------------------------------------------
cmd_doctor() {
    load_profiles
    run_doctor
}

# ------------------------------------------------------------------------------
# Main — Parse arguments and route to subcommand
# ------------------------------------------------------------------------------
main() {
    # No arguments → show brief usage
    if [[ $# -eq 0 ]]; then
        printf >&2 '%bgitsetu%b v%s — One command. All identities. Every machine.\n\n' \
            "$BOLD" "$RESET" "$GITSETU_VERSION"
        printf >&2 'Usage: gitsetu setup [--dry-run]    Start the setup wizard\n'
        printf >&2 '       gitsetu status               Show current identity\n'
        printf >&2 '       gitsetu verify               Test SSH and git config\n'
        printf >&2 '       gitsetu prompt               Print active profile (for PS1)\n'
        printf >&2 '       gitsetu run <profile> -- <cmd>  Run as identity\n'
        printf >&2 '       gitsetu remove <profile>     Remove a specific profile\n'
        printf >&2 '       gitsetu backup [out_file]    Export encrypted state vault\n'
        printf >&2 '       gitsetu restore <in_file>    Import encrypted state vault\n'
        printf >&2 '       gitsetu teardown [--force]   Remove all configurations\n'
        printf >&2 '       gitsetu guard --install      Install commit guard hook\n'
        printf >&2 '       gitsetu --help                Full help\n\n'
        return 0
    fi

    local cmd="$1"
    shift

    case "$cmd" in
        setup)
            # Parse setup flags
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --dry-run)
                        GITSETU_DRY_RUN=1
                        shift
                        ;;
                    *)
                        print_error "Unknown flag: $1"
                        printf >&2 'Usage: gitsetu setup [--dry-run]\n'
                        return 1
                        ;;
                esac
            done
            cmd_setup
            ;;
        add)
            cmd_add "$@"
            ;;
        status)
            cmd_status
            ;;
        verify)
            cmd_verify
            ;;
        run)
            if [[ $# -lt 1 ]]; then
                print_error "Usage: gitsetu run <profile> -- <command>"
                return 1
            fi
            cmd_run "$@"
            ;;
        remove)
            cmd_remove "${1:-}"
            ;;
        backup)
            cmd_backup "$@"
            ;;
        restore)
            cmd_restore "$@"
            ;;
        profile)
            cmd_profile "$@"
            ;;
        prompt)
            cmd_prompt "$@"
            ;;
        credential)
            cmd_credential "$@"
            ;;
        teardown)
            local force=0
            local deep=0
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --dry-run) GITSETU_DRY_RUN=1 ;;
                    --force|-f) force=1 ;;
                    --deep) deep=1 ;;
                    *)
                        print_error "Unknown flag: $1"
                        printf >&2 'Usage: gitsetu teardown [--dry-run] [--force] [--deep]\n'
                        return 1
                        ;;
                esac
                shift
            done
            cmd_teardown "$force" "$deep"
            ;;
        guard)
            if [[ $# -eq 0 ]]; then
                print_error "Usage: gitsetu guard --install | --uninstall"
                return 1
            fi
            case "$1" in
                --install)   detect_os; install_guard ;;
                --uninstall) detect_os; uninstall_guard ;;
                *)
                    print_error "Unknown flag: $1"
                    printf >&2 'Usage: gitsetu guard --install | --uninstall\n'
                    return 1
                    ;;
            esac
            ;;
        doctor)
            cmd_doctor "$@"
            ;;
        --help|-h|help)
            show_help
            ;;
        --version|-v)
            show_version
            ;;
        *)
            print_error "Unknown command: $cmd"
            printf >&2 'Run "gitsetu --help" for usage.\n'
            return 1
            ;;
    esac
}

main "$@"
